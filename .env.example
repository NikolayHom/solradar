# solradar — full env list with defaults
# api/.env  — backend
# web/.env  — frontend (NEXT_PUBLIC_* only)

# ── solana rpc (api side) ──
# helius gives stable devnet throughput vs public rpc
HELIUS_API_KEY=
RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY

# ── persistence ──
# async sqlite for local dev — swap to postgres in prod
DATABASE_URL=sqlite+aiosqlite:///./solradar.db

# ── frontend ──
# next-public vars are bundled into the browser
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MAPBOX_TOKEN=

# ── demo / live mode ──
# set to 1 to use seeded fixtures, 0 to read on-chain via Helius
DEMO_MODE=0
