# SolRadar — DePIN unified analytics API

# --- Solana RPC ---
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
HELIUS_API_KEY=

# --- Database ---
DATABASE_URL=sqlite:///./data/solradar.db

# --- Server ---
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# --- Mode ---
# live | demo | empty
RADAR_MODE=demo

# --- Collector cadences (seconds) ---
HELIUM_REFRESH=300
HIVEMAPPER_REFRESH=3600
RENDER_REFRESH=900

# --- Cache ---
LIVE_CACHE_TTL=60
PROVENANCE_CACHE_TTL=300

# --- Optional: Mapbox token for hosted map style (TopoJSON used as default) ---
MAPBOX_TOKEN=
